# Path to your oh-my-zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Set name of the theme to load
ZSH_THEME="robbyrussell"

# Disable automatic updates
zstyle ':omz:update' mode disabled

# Display red dots whilst waiting for completion
COMPLETION_WAITING_DOTS="true"

# Disable marking untracked files under VCS as dirty
DISABLE_UNTRACKED_FILES_DIRTY="true"

# Which plugins to load (union of both machines)
plugins=(asdf aws chezmoi docker git uv zsh-vi-mode)

source $ZSH/oh-my-zsh.sh

# Hermes CLI completions
eval "$(hermes completion zsh)"

# Preferred editor for local and remote sessions
if [[ -n $SSH_CONNECTION ]]; then
  export EDITOR='vim'
else
  export EDITOR='nvim'
fi

# Aliases
alias zshconfig="vim ~/.zshrc"
alias sshconfig="vim ~/.ssh/config"
alias ohmyzsh="vim ~/.oh-my-zsh"
alias zshrc="source ~/.zshrc"
alias vim="nvim"
alias ls="ls -lah"

# R Environment Configuration
# export R_HOME="$(asdf where r 4.4.0)/lib/R"
export RSTUDIO_WHICH_R="$HOME/.asdf/shims/R"

# Added by LM Studio CLI (lms)
export PATH="$PATH:/Users/saddlerto/.lmstudio/bin"
# End of LM Studio CLI section

fpath+=~/.zfunc

_just_completion() {
    if [[ -f "justfile" ]]; then
      local options
      options="$(just --summary)"
      reply=(${(s: :)options})  # turn into array and write to return variable
    fi
}

compctl -K _just_completion just

# Ensure local bin and ~/bin are in PATH (Hermes Agent uses ~/.local/bin)
export PATH="$HOME/.local/bin:$HOME/bin:$PATH"

# Rust / cargo toolchain
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# Google Cloud SDK
[ -f "$HOME/google-cloud-sdk/path.zsh.inc" ] && . "$HOME/google-cloud-sdk/path.zsh.inc"
[ -f "$HOME/google-cloud-sdk/completion.zsh.inc" ] && . "$HOME/google-cloud-sdk/completion.zsh.inc"

# === NIEHS LiteLLM proxy / SSH gateway ===
# Open a SOCKS5 tunnel through the NIEHS SSH gateway (prompts for PIV PIN).
# Keep the terminal open; Hermes (azure-claude-opus-4.8) and curl route via
# localhost:8080. Stops on Ctrl-C. Keepalives prevent idle drops.
alias niehs-tunnel='ssh -o ServerAliveInterval=60 -o ServerAliveCountMax=3 -I /usr/local/lib/opensc-pkcs11.so -D 8080 -N saddlerto@ssh.niehs.nih.gov'
# Report whether the SOCKS tunnel is currently listening.
alias niehs-tunnel-status='lsof -nP -iTCP:8080 -sTCP:LISTEN >/dev/null 2>&1 && echo "NIEHS SOCKS tunnel :8080 ALIVE" || echo "NIEHS SOCKS tunnel DOWN — run niehs-tunnel"'
# Smoke-test LiteLLM reachability through the tunnel (HTTP 401 = reachable, no key needed).
alias niehs-litellm-test='curl -s -o /dev/null -w "LiteLLM HTTP %{http_code}\n" --max-time 20 -x socks5h://localhost:8080 https://litellm.toxpipe.niehs.nih.gov/v1/models'

# Regenerate the sanitized Hermes config.yaml reference snapshot tracked by chezmoi.
# Usage: hermes-config-ref           (regenerate)
#        hermes-config-ref --check    (CI-style drift check, exit 1 on drift)
alias hermes-config-ref='python3 "$(chezmoi source-path)/scripts/regen-hermes-config-reference.py"'
